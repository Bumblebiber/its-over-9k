{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "O9K_LIMIT_WATCH_CLI=claude node \"${CLAUDE_PLUGIN_ROOT}/scripts/limit-watch.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/usage-stop-collect.mjs\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
