{
  "$comment": "o9k-roster user config. Copied to ~/.o9k/roster.json by 'roster init'. Curate models/roles/chains yourself — o9k ships no live model list. cmd templates are argv arrays; {model} and {prompt} are substituted literally per element. Chain entries may be bare model ids (uses models[m].cli[0]) or CLI×model pins ('cursor:grok-4.5-high' / {\"cli\":\"hermes\",\"model\":\"deepseek-v4-pro\"}).",
  "clis": {
    "claude": { "cmd": ["claude", "--model", "{model}", "{prompt}"] },
    "codex": { "cmd": ["codex", "--model", "{model}", "{prompt}"] },
    "cursor": { "cmd": ["cursor-agent", "--model", "{model}", "{prompt}"] },
    "opencode": { "cmd": ["opencode", "--model", "{model}", "--prompt", "{prompt}"] },
    "hermes": { "cmd": ["hermes", "chat", "-q", "{prompt}", "--model", "{model}"] }
  },
  "models": {
    "claude-fable-5": {
      "provider": "anthropic",
      "tier": "frontier",
      "cli": ["claude"],
      "price": { "in": null, "out": null, "note": "fill in per effort level" },
      "strengths": ["architecture", "review"],
      "weaknesses": ["cost"]
    },
    "claude-opus": {
      "provider": "anthropic",
      "tier": "high",
      "cli": ["claude"]
    },
    "claude-sonnet-5": {
      "provider": "anthropic",
      "tier": "mid",
      "cli": ["claude"]
    },
    "claude-haiku": {
      "provider": "anthropic",
      "tier": "low",
      "cli": ["claude"]
    },
    "gpt-5.6-sol": {
      "provider": "openai",
      "tier": "frontier",
      "cli": ["codex"]
    },
    "gpt-5.6-terra": {
      "provider": "openai",
      "tier": "high",
      "cli": ["codex"]
    },
    "gpt-5.6-luna": {
      "provider": "openai",
      "tier": "mid",
      "cli": ["codex"]
    },
    "gpt-5.4-mini": {
      "provider": "openai",
      "tier": "low",
      "cli": ["codex"]
    },
    "composer-2.5": {
      "provider": "cursor",
      "tier": "mid",
      "cli": ["cursor"]
    },
    "grok-4.5-high": {
      "provider": "xai",
      "tier": "high",
      "cli": ["cursor", "opencode", "hermes"]
    },
    "deepseek-v4-pro": {
      "provider": "deepseek",
      "tier": "mid",
      "cli": ["hermes", "opencode"]
    },
    "deepseek-v4-flash": {
      "provider": "deepseek",
      "tier": "low",
      "cli": ["hermes", "opencode"]
    }
  },
  "roles": {
    "planner": {
      "chain": [
        "claude:claude-fable-5",
        "codex:gpt-5.6-sol",
        "claude:claude-opus",
        "codex:gpt-5.6-terra"
      ]
    },
    "reviewer": {
      "chain": [
        "claude:claude-fable-5",
        "claude:claude-opus",
        "codex:gpt-5.6-terra"
      ]
    },
    "implementer": {
      "chain": [
        "cursor:composer-2.5",
        "cursor:grok-4.5-high",
        "codex:gpt-5.6-luna",
        "claude:claude-sonnet-5",
        "hermes:deepseek-v4-pro"
      ]
    },
    "researcher": {
      "chain": [
        "codex:gpt-5.6-luna",
        "claude:claude-sonnet-5",
        "hermes:deepseek-v4-pro"
      ]
    },
    "prompt-writer": {
      "chain": ["claude:claude-sonnet-5", "codex:gpt-5.6-luna"]
    },
    "frontend-designer": {
      "chain": [
        "cursor:composer-2.5",
        "cursor:grok-4.5-high",
        "claude:claude-sonnet-5",
        "codex:gpt-5.6-luna"
      ]
    },
    "triager": {
      "chain": [
        "claude:claude-haiku",
        "codex:gpt-5.4-mini",
        "hermes:deepseek-v4-flash"
      ]
    },
    "scout": {
      "chain": [
        "claude:claude-haiku",
        "hermes:deepseek-v4-flash",
        "codex:gpt-5.4-mini"
      ]
    },
    "summarizer": {
      "chain": [
        "hermes:deepseek-v4-flash",
        "claude:claude-haiku",
        "codex:gpt-5.4-mini"
      ]
    },
    "test-writer": {
      "chain": [
        "claude:claude-sonnet-5",
        "cursor:composer-2.5",
        "codex:gpt-5.6-luna"
      ]
    }
  },
  "limits": { "warn_at": 0.9, "handoff_at": 0.95 }
}
