[Unit]
Description=o9k-roster adaptive subscription usage watcher
After=default.target

[Service]
Type=simple
Restart=always
RestartSec=10
# Install wrapper (never ExecStart a bare .mjs — ENOEXEC without shebang):
#   install -m 0755 <repo>/plugins/o9k-roster/scripts/o9k-usage-watcher.sh ~/.local/bin/o9k-usage-watcher
# Copy installs need the scripts path; symlink is preferred:
#   ln -sf <repo>/plugins/o9k-roster/scripts/o9k-usage-watcher.sh ~/.local/bin/o9k-usage-watcher
# Or set Environment=O9K_ROSTER_SCRIPTS=<repo>/plugins/o9k-roster/scripts in a drop-in.
ExecStart=%h/.local/bin/o9k-usage-watcher

[Install]
WantedBy=default.target
